      "source": [
        "import sys\n",
        "\n",
        "def f(x, y):\n",
        "    return (x + y) * (x + y + 1) // 2 + x\n",
        "\n",
        "t = int(sys.stdin.readline())\n",
        "\n",
        "for i in range(1, t + 1):\n",
        "    x1, y1, x2, y2 = map(int, sys.stdin.readline().split())\n",
        "    steps = f(x2, y2) - f(x1, y1)\n",
        "    print(f\"Case {i}: {steps}\")"
      ]
    }
  ]
}