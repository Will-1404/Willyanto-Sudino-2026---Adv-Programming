      "source": [
        "import sys\n",
        "\n",
        "for line in sys.stdin:\n",
        "    n = int(line.strip())\n",
        "    if n == 0:\n",
        "        break\n",
        "\n",
        "    if n % 9 == 0:\n",
        "        print(9)\n",
        "    else:\n",
        "        print(n % 9)"
      ]
    }
  ]
