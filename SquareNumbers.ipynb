      "source": [
        "import math\n",
        "\n",
        "while True:\n",
        "    a, b = map(int, input().split())\n",
        "\n",
        "    if a == 0 and b == 0:\n",
        "        break\n",
        "\n",
        "    left = math.ceil(math.sqrt(a))\n",
        "    right = math.floor(math.sqrt(b))\n",
        "\n",
        "    print(right - left + 1)"
      ]
    }
  ]
}